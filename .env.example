# ─── Sepolia Testnet ──────────────────────────────────────────────────────
# Get your free RPC URL from Alchemy: https://alchemy.com
# Create app → Ethereum → Sepolia → copy the HTTPS URL
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY_HERE

# Export from MetaMask: Settings → Account Details → Export Private Key
# ⚠️  Use a TEST wallet ONLY — never your main wallet
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ─── Optional ─────────────────────────────────────────────────────────────
# Override the contract address (auto-loaded from deployed.json if not set)
# CONTRACT_ADDRESS=0x...

# How often the keeper checks gas prices (default: 30 seconds)
# POLL_INTERVAL_SECONDS=30
